@page "/chat"

@using Shared.Models
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using Gotorz.Client.Services

@inject ChatService ChatService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager
@rendermode InteractiveWebAssembly
@attribute [Authorize]

<PageTitle>Travel Chat</PageTitle>

<div class="container-fluid chat-container">
    <div class="row h-100">
        <div class="col-md-3 chat-sidebar">
            <div class="chat-rooms-header">
                <h5>Chat Rooms</h5>
            </div>
            <div class="chat-rooms-list">
                @foreach (var room in chatRooms)
                {
                    <div class="chat-room-item @(selectedRoom?.Id == room.Id ? "active" : "")" @onclick="() => SelectRoom(room)">
                        <div class="room-name">@room.Name</div>
                        <div class="room-description">@room.Description</div>
                    </div>
                }
            </div>
        </div>
        <div class="col-md-9 chat-main">
            @if (selectedRoom == null)
            {
                <div class="no-room-selected">
                    <div class="text-center">
                        <h4>Welcome to GodTur Chat</h4>
                        <p>Select a chat room to start messaging with other travelers or our support team.</p>
                    </div>
                </div>
            }
            else
            {
                <div class="chat-header">
                    <h5>@selectedRoom.Name</h5>
                    <div class="chat-description">@selectedRoom.Description</div>
                </div>
                <div class="chat-messages" id="messageContainer" @ref="messageContainer">
                    @foreach (var message in currentMessages)
                    {
                        <div class="message-container @(message.SenderId == currentUserId ? "message-outgoing" : "message-incoming")">
                            <div class="message-bubble">
                                <div class="message-sender">@message.SenderName</div>
                                <div class="message-content">@message.Content</div>
                                <div class="message-time">@message.Timestamp.ToString("HH:mm")</div>
                            </div>
                        </div>
                    }
                    @if (isAgentTyping)
                    {
                        <div class="message-container message-incoming">
                            <div class="message-bubble typing-indicator">
                                <span></span>
                                <span></span>
                                <span></span>
                            </div>
                        </div>
                    }
                </div>
                <div class="chat-input">
                    <div class="input-group">
                        <input type="text" class="form-control" placeholder="Type your message here..." 
                            @bind="newMessage" 
                            @bind:event="oninput" 
                            @onkeydown="HandleKeyDown" />
                        <button class="btn btn-primary" @onclick="SendMessage" disabled="@string.IsNullOrWhiteSpace(newMessage)">
                            <i class="bi bi-send"></i> Send
                        </button>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private List<ChatRoom> chatRooms = new();
    private ChatRoom selectedRoom;
    private List<ChatMessage> currentMessages = new();
    private string newMessage;
    private string currentUserId;
    private string currentUserName;
    private bool isAgentTyping = false;
    private ElementReference messageContainer;
    
    protected override async Task OnInitializedAsync()
    {
        // Get current user info
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        
        if (user.Identity.IsAuthenticated)
        {
            currentUserId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "anonymous";
            currentUserName = user.Identity.Name?.Split('@').FirstOrDefault() ?? "User";
        }
        
        // Load chat rooms
        chatRooms = ChatService.GetChatRooms();
        
        // Subscribe to new messages
        ChatService.OnMessageReceived += HandleNewMessage;
    }
    
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await ScrollToBottom();
    }
    
    private void HandleNewMessage(ChatMessage message)
    {
        // Only update if the message belongs to the current room
        if (selectedRoom != null && message.RoomId == selectedRoom.Id)
        {
            currentMessages.Add(message);
            StateHasChanged();
            _ = ScrollToBottom();
        }
    }
    
    private void SelectRoom(ChatRoom room)
    {
        selectedRoom = room;
        currentMessages = ChatService.GetMessagesForRoom(room.Id);
        
        // Check if this is the first time joining this room
        if (currentMessages.All(m => m.SenderId != "system" || !m.Content.Contains("joined")))
        {
            // Add a join message
            ChatService.AddChatMessage(new ChatMessage
            {
                RoomId = room.Id,
                SenderId = "system",
                SenderName = "System",
                Content = $"{currentUserName} has joined the chat.",
                Timestamp = DateTime.Now
            });
        }
        
        StateHasChanged();
    }
    
    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(newMessage))
        {
            await SendMessage();
        }
    }
    
    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(newMessage) || selectedRoom == null)
            return;
            
        // Create and add message
        var message = new ChatMessage
        {
            RoomId = selectedRoom.Id,
            SenderId = currentUserId,
            SenderName = currentUserName,
            Content = newMessage.Trim(),
            Timestamp = DateTime.Now
        };
        
        ChatService.AddChatMessage(message);
        
        // Clear input
        newMessage = string.Empty;
        
        // Simulate agent response if this is a support room
        if (selectedRoom.Type == ChatRoomType.Support)
        {
            isAgentTyping = true;
            StateHasChanged();
            
            // Simulate agent typing and response
            await ChatService.SimulateAgentResponse(selectedRoom.Id, message.Content);
            
            isAgentTyping = false;
            StateHasChanged();
        }
    }
    
    private async Task ScrollToBottom()
    {
        try
        {
            if (messageContainer.Context != null)
            {
                await JSRuntime.InvokeVoidAsync("scrollToBottom", messageContainer);
            }
        }
        catch
        {
            // Ignore errors
        }
    }
    
    public void Dispose()
    {
        // Unsubscribe from events
        ChatService.OnMessageReceived -= HandleNewMessage;
    }
}

<style>
    .chat-container {
        height: calc(100vh - 200px);
        overflow: hidden;
    }
    
    .chat-sidebar {
        background-color: #f8f9fa;
        border-right: 1px solid #dee2e6;
        height: 100%;
        overflow-y: auto;
        padding: 0;
    }
    
    .chat-rooms-header {
        padding: 15px;
        border-bottom: 1px solid #dee2e6;
        background-color: #e9ecef;
    }
    
    .chat-rooms-list {
        overflow-y: auto;
    }
    
    .chat-room-item {
        padding: 15px;
        border-bottom: 1px solid #dee2e6;
        cursor: pointer;
        transition: background-color 0.2s;
    }
    
    .chat-room-item:hover {
        background-color: #e9ecef;
    }
    
    .chat-room-item.active {
        background-color: #e2e6ea;
        border-left: 4px solid #0d6efd;
    }
    
    .room-name {
        font-weight: bold;
    }
    
    .room-description {
        font-size: 0.85rem;
        color: #6c757d;
    }
    
    .chat-main {
        display: flex;
        flex-direction: column;
        height: 100%;
        padding: 0;
    }
    
    .chat-header {
        padding: 15px;
        border-bottom: 1px solid #dee2e6;
        background-color: #f8f9fa;
    }
    
    .no-room-selected {
        display: flex;
        align-items: center;
        justify-content: center;
        height: 100%;
        background-color: #f8f9fa;
    }
    
    .chat-messages {
        flex: 1;
        padding: 15px;
        overflow-y: auto;
        background-color: #fff;
    }
    
    .message-container {
        margin-bottom: 15px;
        display: flex;
    }
    
    .message-incoming {
        justify-content: flex-start;
    }
    
    .message-outgoing {
        justify-content: flex-end;
    }
    
    .message-bubble {
        max-width: 70%;
        padding: 10px 15px;
        border-radius: 18px;
        position: relative;
    }
    
    .message-incoming .message-bubble {
        background-color: #f1f0f0;
        border-bottom-left-radius: 5px;
    }
    
    .message-outgoing .message-bubble {
        background-color: #d1e7ff;
        border-bottom-right-radius: 5px;
    }
    
    .message-sender {
        font-size: 0.8rem;
        font-weight: bold;
        margin-bottom: 5px;
    }
    
    .message-time {
        font-size: 0.7rem;
        color: #6c757d;
        text-align: right;
        margin-top: 5px;
    }
    
    .chat-input {
        padding: 15px;
        border-top: 1px solid #dee2e6;
    }
    
    /* Typing indicator */
    .typing-indicator {
        background-color: #f1f0f0;
        padding: 10px 15px;
        display: flex;
        align-items: center;
    }
    
    .typing-indicator span {
        height: 8px;
        width: 8px;
        float: left;
        margin: 0 1px;
        background-color: #9e9ea1;
        display: block;
        border-radius: 50%;
        opacity: 0.4;
    }
    
    .typing-indicator span:nth-of-type(1) {
        animation: typing 1s infinite;
    }
    
    .typing-indicator span:nth-of-type(2) {
        animation: typing 1s 0.33s infinite;
    }
    
    .typing-indicator span:nth-of-type(3) {
        animation: typing 1s 0.66s infinite;
    }
    
    @keyframes typing {
        0% {
            transform: translateY(0);
        }
        
        50% {
            transform: translateY(-5px);
        }
        
        100% {
            transform: translateY(0);
        }
    }
</style>

@inject IJSRuntime JSRuntime

<script>
    window.scrollToBottom = function (element) {
        element.scrollTop = element.scrollHeight;
    }
</script>