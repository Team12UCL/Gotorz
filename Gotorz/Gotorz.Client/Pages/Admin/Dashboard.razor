@page "/admin/dashboard"

@using Shared.Models
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using Gotorz.Client.Services

@inject TravelPackageService PackageService
@inject ActivityLogService ActivityLogService
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthStateProvider
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveWebAssembly

<PageTitle>Admin Dashboard</PageTitle>

<h3>Admin Dashboard</h3>

<div class="row mb-4">
    <div class="col-md-3">
        <div class="card text-white bg-primary mb-3">
            <div class="card-body">
                <h5 class="card-title">Total Bookings</h5>
                <p class="card-text fs-2">@totalBookings</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-success mb-3">
            <div class="card-body">
                <h5 class="card-title">Completed Bookings</h5>
                <p class="card-text fs-2">@completedBookings</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-warning mb-3">
            <div class="card-body">
                <h5 class="card-title">Pending Bookings</h5>
                <p class="card-text fs-2">@pendingBookings</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-danger mb-3">
            <div class="card-body">
                <h5 class="card-title">Cancelled Bookings</h5>
                <p class="card-text fs-2">@cancelledBookings</p>
            </div>
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Recent Bookings</h5>
                <div>
                    <button class="btn btn-sm btn-outline-primary" @onclick="ExportBookings">Export</button>
                </div>
            </div>
            <div class="card-body">
                @if (isLoadingBookings)
                {
                    <div class="text-center py-3">
                        <div class="spinner-border" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                    </div>
                }
                else if (allBookings.Count == 0)
                {
                    <p class="text-center py-3">No bookings found.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead>
                                <tr>
                                    <th>Reference</th>
                                    <th>Customer</th>
                                    <th>Destination</th>
                                    <th>Travel Dates</th>
                                    <th>Status</th>
                                    <th>Amount</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var booking in allBookings.Take(10))
                                {
                                    <tr>
                                        <td>@booking.ReferenceNumber</td>
                                        <td>@booking.UserId</td>
                                        <td>@GetDestination(booking.Package)</td>
                                        <td>
                                            @booking.TravelStartDate.ToString("MMM d") - 
                                            @booking.TravelEndDate.ToString("MMM d, yyyy")
                                        </td>
                                        <td>
                                            <span class="badge @GetStatusBadgeClass(booking.Status)">
                                                @booking.Status
                                            </span>
                                        </td>
                                        <td>€@booking.TotalAmount</td>
                                        <td>
                                            <button class="btn btn-sm btn-outline-primary" @onclick="() => ViewBookingDetails(booking)">
                                                View
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    
                    @if (allBookings.Count > 10)
                    {
                        <div class="text-center">
                            <a href="/admin/bookings" class="btn btn-link">View All Bookings</a>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Recent Activity Logs</h5>
                <div>
                    <button class="btn btn-sm btn-outline-primary" @onclick="ExportLogs">Export</button>
                </div>
            </div>
            <div class="card-body">
                @if (isLoadingLogs)
                {
                    <div class="text-center py-3">
                        <div class="spinner-border" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                    </div>
                }
                else if (activityLogs.Count == 0)
                {
                    <p class="text-center py-3">No activity logs found.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead>
                                <tr>
                                    <th>Timestamp</th>
                                    <th>User</th>
                                    <th>Action</th>
                                    <th>Details</th>
                                    <th>IP Address</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var log in activityLogs.Take(10))
                                {
                                    <tr>
                                        <td>@log.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")</td>
                                        <td>@log.UserId</td>
                                        <td>@log.Action</td>
                                        <td>@log.Details</td>
                                        <td>@log.IpAddress</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    
                    @if (activityLogs.Count > 10)
                    {
                        <div class="text-center">
                            <a href="/admin/logs" class="btn btn-link">View All Logs</a>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>

@if (selectedBooking != null)
{
    <div class="modal fade show" style="display: block;" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Booking Details: @selectedBooking.ReferenceNumber</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-6">
                            <h6>Flight Information</h6>
                            <div class="mb-3">
                                <strong>Outbound</strong><br />
                                @selectedBooking.Package.OutboundFlight.Itineraries[0].Segments[0].Departure.IataCode →
                                @selectedBooking.Package.OutboundFlight.Itineraries[0].Segments[^1].Arrival.IataCode<br />
                                @selectedBooking.Package.OutboundFlight.Itineraries[0].Segments[0].Departure.At.ToString("MMM d, yyyy HH:mm")
                            </div>
                            
                            @if (selectedBooking.Package.ReturnFlight != null)
                            {
                                <div class="mb-3">
                                    <strong>Return</strong><br />
                                    @selectedBooking.Package.ReturnFlight.Itineraries[0].Segments[0].Departure.IataCode →
                                    @selectedBooking.Package.ReturnFlight.Itineraries[0].Segments[^1].Arrival.IataCode<br />
                                    @selectedBooking.Package.ReturnFlight.Itineraries[0].Segments[0].Departure.At.ToString("MMM d, yyyy HH:mm")
                                </div>
                            }
                        </div>
                        <div class="col-md-6">
                            <h6>Hotel Information</h6>
                            <div class="mb-3">
                                <strong>@selectedBooking.Package.Hotel.Hotel.Name</strong><br />
                                Check-in: @selectedBooking.Package.Hotel.Offers[0].CheckInDate<br />
                                Check-out: @selectedBooking.Package.Hotel.Offers[0].CheckOutDate<br />
                                Room: @selectedBooking.Package.Hotel.Offers[0].RoomType
                            </div>
                        </div>
                    </div>
                    <hr />
                    <div class="row">
                        <div class="col-md-6">
                            <h6>Payment Information</h6>
                            <p>Status: <span class="badge @GetPaymentBadgeClass(selectedBooking.PaymentStatus)">@selectedBooking.PaymentStatus</span></p>
                            <p>Total Amount: €@selectedBooking.TotalAmount</p>
                            <p>Payment Date: @selectedBooking.BookingDate.ToString("MMM d, yyyy")</p>
                        </div>
                        <div class="col-md-6">
                            <h6>Booking Status</h6>
                            <div class="mb-3">
                                <select class="form-select" @bind="selectedStatus">
                                    @foreach (var status in Enum.GetValues(typeof(BookingStatus)))
                                    {
                                        <option value="@status">@status</option>
                                    }
                                </select>
                            </div>
                            <button class="btn btn-primary" @onclick="UpdateBookingStatus">Update Status</button>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModal">Close</button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@if (showExportMessage)
{
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 9999">
        <div class="toast show" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="toast-header">
                <strong class="me-auto">Export Complete</strong>
                <button type="button" class="btn-close" @onclick="() => showExportMessage = false"></button>
            </div>
            <div class="toast-body">
                @exportFileName has been downloaded to your device.
            </div>
        </div>
    </div>
}

@code {
    private List<Booking> allBookings = new();
    private List<ActivityLog> activityLogs = new();
    private Booking selectedBooking;
    private BookingStatus selectedStatus;
    private bool isLoadingBookings = true;
    private bool isLoadingLogs = true;
    private bool showExportMessage = false;
    private string exportFileName;
    
    // Dashboard stats
    private int totalBookings;
    private int completedBookings;
    private int pendingBookings;
    private int cancelledBookings;
    
    protected override async Task OnInitializedAsync()
    {
        await LoadBookings();
        await LoadActivityLogs();
        
        // Add some mock data for demonstration
        AddMockActivityLogs();
        
        CalculateStats();
    }
    
    private async Task LoadBookings()
    {
        isLoadingBookings = true;
        
        try
        {
            // In a real implementation, this would fetch from a database
            allBookings = PackageService.Bookings;
        }
        finally
        {
            isLoadingBookings = false;
        }
    }
    
    private async Task LoadActivityLogs()
    {
        isLoadingLogs = true;
        
        try
        {
            // In a real implementation, this would fetch from a database
            activityLogs = ActivityLogService.GetAllLogs();
        }
        finally
        {
            isLoadingLogs = false;
        }
    }
    
    private void AddMockActivityLogs()
    {
        // Add some mock activity logs if none exist
        if (activityLogs.Count == 0)
        {
            ActivityLogService.LogActivity("user1", "Login", "User logged in");
            ActivityLogService.LogActivity("user1", "Search", "User searched for flights to Paris");
            ActivityLogService.LogActivity("user1", "Booking", "User created booking GDT-230412-5678");
            ActivityLogService.LogActivity("user1", "Payment", "User completed payment for booking GDT-230412-5678");
            ActivityLogService.LogActivity("user2", "Login", "User logged in");
            ActivityLogService.LogActivity("user2", "Search", "User searched for flights to London");
            ActivityLogService.LogActivity("admin1", "Login", "Admin logged in");
            ActivityLogService.LogActivity("admin1", "User Management", "Admin reset password for user3");
            
            // Reload logs
            activityLogs = ActivityLogService.GetAllLogs();
        }
    }
    
    private void CalculateStats()
    {
        totalBookings = allBookings.Count;
        completedBookings = allBookings.Count(b => b.Status == BookingStatus.Completed);
        pendingBookings = allBookings.Count(b => b.Status == BookingStatus.Pending);
        cancelledBookings = allBookings.Count(b => b.Status == BookingStatus.Cancelled);
    }
    
    private string GetDestination(TravelPackage package)
    {
        return package?.OutboundFlight?.Itineraries[0]?.Segments[^1]?.Arrival?.IataCode ?? "Unknown";
    }
    
    private string GetStatusBadgeClass(BookingStatus status)
    {
        return status switch
        {
            BookingStatus.Confirmed => "bg-success",
            BookingStatus.Pending => "bg-warning",
            BookingStatus.Cancelled => "bg-danger",
            BookingStatus.Completed => "bg-info",
            _ => "bg-secondary"
        };
    }
    
    private string GetPaymentBadgeClass(PaymentStatus status)
    {
        return status switch
        {
            PaymentStatus.Paid => "bg-success",
            PaymentStatus.Pending => "bg-warning",
            PaymentStatus.Failed => "bg-danger",
            PaymentStatus.Refunded => "bg-info",
            _ => "bg-secondary"
        };
    }
    
    private void ViewBookingDetails(Booking booking)
    {
        selectedBooking = booking;
        selectedStatus = booking.Status;
    }
    
    private void CloseModal()
    {
        selectedBooking = null;
    }
    
    private void UpdateBookingStatus()
    {
        if (selectedBooking != null)
        {
            // Update the booking status
            selectedBooking.Status = selectedStatus;
            
            // If cancelled, update payment status to refunded
            if (selectedStatus == BookingStatus.Cancelled && selectedBooking.PaymentStatus == PaymentStatus.Paid)
            {
                selectedBooking.PaymentStatus = PaymentStatus.Refunded;
            }
            
            // Log the activity
            ActivityLogService.LogActivity("admin", "Booking Update", 
                $"Updated booking {selectedBooking.ReferenceNumber} status to {selectedStatus}");
                
            // Refresh stats
            CalculateStats();
            
            // Close the modal
            CloseModal();
        }
    }
    
    private async Task ExportBookings()
    {
        // Simulate exporting to CSV
        exportFileName = $"bookings_export_{DateTime.Now:yyyyMMdd}.csv";
        showExportMessage = true;
        
        // Log activity
        ActivityLogService.LogActivity("admin", "Export", "Exported bookings to CSV");
        
        // In a real implementation, this would generate and download a CSV file
        await Task.Delay(1000);
    }
    
    private async Task ExportLogs()
    {
        // Simulate exporting to CSV
        exportFileName = $"activity_logs_{DateTime.Now:yyyyMMdd}.csv";
        showExportMessage = true;
        
        // Log activity
        ActivityLogService.LogActivity("admin", "Export", "Exported activity logs to CSV");
        
        // In a real implementation, this would generate and download a CSV file
        await Task.Delay(1000);
    }
}