@page "/dashboard"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization

@using System.Text.Json
@using Shared.Models
@attribute [Authorize(Roles = "Customer")]
@inject HttpClient Http
@inject ILogger<CustomerDashboard> Logger
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>GodTur - Your Dashboard</PageTitle>

<div class="customer-dashboard">
    <h1 class="mb-4">Welcome, @(_userName ?? "Traveler")</h1>

    @if (_isLoading)
    {
        <div class="text-center">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else
    {
        <div class="row mb-4">
            <div class="col-md-4">
                <div class="card bg-primary text-white h-100">
                    <div class="card-body">
                        <h5 class="card-title">Your Bookings</h5>
                        <h2 class="display-4">@(_bookings?.Count ?? 0)</h2>
                        <p class="card-text">Total travel packages booked</p>
                    </div>
                    <div class="card-footer d-flex justify-content-between align-items-center">
                        <a href="/bookings" class="text-white">View all bookings</a>
                        <i class="bi bi-arrow-right text-white"></i>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card bg-info text-white h-100">
                    <div class="card-body">
                        <h5 class="card-title">Upcoming Trip</h5>
                        @if (_upcomingBooking != null)
                        {
                            <h3>@_upcomingBooking.TravelPackage?.Name</h3>
                            <p class="card-text">
                                Departure: @_upcomingBooking.DepartureDate.ToString("MMM d, yyyy")
                            </p>
                        }
                        else
                        {
                            <p class="card-text">No upcoming trips</p>
                            <a href="/search" class="btn btn-light mt-2">Find your next adventure</a>
                        }
                    </div>
                    @if (_upcomingBooking != null)
                    {
                        <div class="card-footer d-flex justify-content-between align-items-center">
                            <a href="/bookings/@_upcomingBooking.Id" class="text-white">View details</a>
                            <i class="bi bi-arrow-right text-white"></i>
                        </div>
                    }
                </div>
            </div>
            <div class="col-md-4">
                <div class="card bg-success text-white h-100">
                    <div class="card-body">
                        <h5 class="card-title">Travel Guides</h5>
                        <p class="card-text">Access destination guides for your booked trips</p>
                        <div class="mt-3">
                            @if (_recentDestinations != null && _recentDestinations.Any())
                            {
                                @foreach (var destination in _recentDestinations)
                                {
                                    <a href="/travel-guides/@destination" class="badge bg-light text-dark me-1">@destination</a>
                                }
                            }
                            else
                            {
                                <p>No destinations booked yet</p>
                            }
                        </div>
                    </div>
                    <div class="card-footer d-flex justify-content-between align-items-center">
                        <a href="/travel-guides" class="text-white">Browse all guides</a>
                        <i class="bi bi-arrow-right text-white"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="row mb-4">
            <div class="col-md-8">
                <div class="card h-100">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">Your Recent Bookings</h5>
                        <a href="/bookings" class="btn btn-sm btn-primary">View All</a>
                    </div>
                    <div class="card-body">
                        @if (_bookings != null && _bookings.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-hover">
                                    <thead>
                                        <tr>
                                            <th>Booking Reference</th>
                                            <th>Destination</th>
                                            <th>Dates</th>
                                            <th>Status</th>
                                            <th>Price</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var booking in _bookings.Take(5))
                                        {
                                            <tr>
                                                <td><a href="/bookings/@booking.Id">@booking.BookingReference</a></td>
                                                <td>@booking.TravelPackage?.Destination</td>
                                                <td>@booking.DepartureDate.ToString("MMM d") - @booking.ReturnDate.ToString("MMM d, yyyy")</td>
                                                <td><span class="badge @GetBookingStatusClass(booking.Status)">@booking.Status</span></td>
                                                <td>@booking.TotalPrice.ToString("C")</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="text-center py-5">
                                <h5>No bookings yet</h5>
                                <p class="text-muted">Book your first trip to get started!</p>
                                <a href="/search" class="btn btn-primary mt-2">Explore Destinations</a>
                            </div>
                        }
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100">
                    <div class="card-header">
                        <h5 class="mb-0">Quick Actions</h5>
                    </div>
                    <div class="card-body">
                        <div class="list-group">
                            <a href="/search" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                                <div>
                                    <i class="bi bi-search me-2"></i>
                                    Search Destinations
                                </div>
                                <i class="bi bi-chevron-right"></i>
                            </a>
                            <a href="/bookings" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                                <div>
                                    <i class="bi bi-calendar-check me-2"></i>
                                    Manage Bookings
                                </div>
                                <i class="bi bi-chevron-right"></i>
                            </a>
                            <a href="/support" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                                <div>
                                    <i class="bi bi-headset me-2"></i>
                                    Contact Support
                                </div>
                                <i class="bi bi-chevron-right"></i>
                            </a>
                            <a href="/travel-guides" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                                <div>
                                    <i class="bi bi-book me-2"></i>
                                    Browse Travel Guides
                                </div>
                                <i class="bi bi-chevron-right"></i>
                            </a>
                            <a href="/account/profile" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                                <div>
                                    <i class="bi bi-person-circle me-2"></i>
                                    Update Profile
                                </div>
                                <i class="bi bi-chevron-right"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row mb-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">Recommended Destinations</h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            @foreach (var package in _recommendedPackages)
                            {
                                <div class="col-md-4 mb-3">
                                    <div class="card h-100">
                                        <img src="@package.ImageUrl" class="card-img-top" alt="@package.Name" 
                                             style="height: 150px; object-fit: cover;">
                                        <div class="card-body">
                                            <h5 class="card-title">@package.Name</h5>
                                            <p class="card-text text-muted">@package.Destination</p>
                                            <p class="card-text fw-bold">@package.BasePrice.ToString("C")</p>
                                        </div>
                                        <div class="card-footer bg-white border-top-0">
                                            <a href="/packages/@package.Id" class="btn btn-outline-primary w-100">View Details</a>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool _isLoading = true;
    private string _userName;
    private List<Booking> _bookings = new();
    private Booking _upcomingBooking;
    private List<string> _recentDestinations = new();
    private List<TravelPackage> _recommendedPackages = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            
            if (user.Identity.IsAuthenticated)
            {
                _userName = user.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value;
                
                // If no first name claim, use the first part of the email
                if (string.IsNullOrEmpty(_userName))
                {
                    var email = user.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value;
                    _userName = email?.Split('@').FirstOrDefault();
                }
                
                var userId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                
                if (!string.IsNullOrEmpty(userId))
                {
                    await LoadUserBookings(userId);
                    await LoadRecommendedPackages();
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading customer dashboard data");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadUserBookings(string userId)
    {
        try
        {
            var response = await Http.GetAsync($"api/bookings/user/{userId}");
            
            if (response.IsSuccessStatusCode)
            {
                var content = await response.Content.ReadAsStringAsync();
                _bookings = JsonSerializer.Deserialize<List<Booking>>(content, new JsonSerializerOptions
                {
                    PropertyNameCaseInsensitive = true
                }) ?? new List<Booking>();
                
                // Find upcoming bookings
                _upcomingBooking = _bookings
                    .Where(b => b.DepartureDate > DateTime.Now && b.Status != "Cancelled")
                    .OrderBy(b => b.DepartureDate)
                    .FirstOrDefault();
                
                // Extract unique destinations
                _recentDestinations = _bookings
                    .Where(b => b.TravelPackage != null)
                    .Select(b => b.TravelPackage.Destination)
                    .Distinct()
                    .Take(5)
                    .ToList();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading user bookings");
        }
    }

    private async Task LoadRecommendedPackages()
    {
        try
        {
            var response = await Http.GetAsync("api/travelpackage?take=3");
            
            if (response.IsSuccessStatusCode)
            {
                var content = await response.Content.ReadAsStringAsync();
                _recommendedPackages = JsonSerializer.Deserialize<List<TravelPackage>>(content, new JsonSerializerOptions
                {
                    PropertyNameCaseInsensitive = true
                }) ?? new List<TravelPackage>();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading recommended packages");
        }
    }

    private string GetBookingStatusClass(string status)
    {
        return status?.ToLower() switch
        {
            "confirmed" => "bg-success",
            "pending" => "bg-warning",
            "cancelled" => "bg-danger",
            "completed" => "bg-info",
            _ => "bg-secondary"
        };
    }
}