@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization

<PageTitle>GodTur Travel Platform</PageTitle>

<div class="page">
    <AuthorizeView>
        <Authorized>
            <div class="top-row user-info px-4">
                <div class="dropdown">
                    <button class="btn btn-link dropdown-toggle nav-link" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="bi bi-person-circle me-1"></i> Hello, @context.User.Identity.Name!
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><a class="dropdown-item" href="account"><i class="bi bi-person me-2"></i>My Profile</a></li>
                        <li><a class="dropdown-item" href="my-bookings"><i class="bi bi-briefcase me-2"></i>My Bookings</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item" href="account/logout"><i class="bi bi-box-arrow-right me-2"></i>Logout</a></li>
                    </ul>
                </div>
            </div>
        </Authorized>
        <NotAuthorized>
            <div class="top-row user-info px-4">
                <a href="account/register" class="nav-link me-3">
                    <i class="bi bi-person-plus me-1"></i> Register
                </a>
                <a href="account/login" class="btn btn-primary btn-sm">
                    <i class="bi bi-box-arrow-in-right me-1"></i> Login
                </a>
            </div>
        </NotAuthorized>
    </AuthorizeView>

    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <article class="content px-0">
            @Body
        </article>
        
        <footer class="bg-dark text-white py-4 mt-5">
            <div class="container">
                <div class="row">
                    <div class="col-md-4 mb-4 mb-md-0">
                        <h5>GodTur Travel</h5>
                        <p class="text-muted">
                            Your trusted travel partner since 2023. We offer the best deals on flights and hotels worldwide.
                        </p>
                        <div class="d-flex mt-3">
                            <a href="#" class="text-white me-3"><i class="bi bi-facebook fs-5"></i></a>
                            <a href="#" class="text-white me-3"><i class="bi bi-twitter fs-5"></i></a>
                            <a href="#" class="text-white me-3"><i class="bi bi-instagram fs-5"></i></a>
                            <a href="#" class="text-white"><i class="bi bi-linkedin fs-5"></i></a>
                        </div>
                    </div>
                    <div class="col-md-2 mb-4 mb-md-0">
                        <h6>Explore</h6>
                        <ul class="list-unstyled">
                            <li><a href="destinations" class="text-muted">Destinations</a></li>
                            <li><a href="deals" class="text-muted">Special Deals</a></li>
                            <li><a href="hotels" class="text-muted">Hotels</a></li>
                            <li><a href="flights" class="text-muted">Flights</a></li>
                        </ul>
                    </div>
                    <div class="col-md-2 mb-4 mb-md-0">
                        <h6>Company</h6>
                        <ul class="list-unstyled">
                            <li><a href="about" class="text-muted">About Us</a></li>
                            <li><a href="contact" class="text-muted">Contact Us</a></li>
                            <li><a href="careers" class="text-muted">Careers</a></li>
                            <li><a href="blog" class="text-muted">Blog</a></li>
                        </ul>
                    </div>
                    <div class="col-md-4">
                        <h6>Subscribe to our newsletter</h6>
                        <p class="text-muted">Get the latest deals and travel updates</p>
                        <div class="input-group mb-3">
                            <input type="email" class="form-control" placeholder="Your email">
                            <button class="btn btn-primary" type="button">Subscribe</button>
                        </div>
                    </div>
                </div>
                <hr class="my-4">
                <div class="row align-items-center">
                    <div class="col-md-6 text-center text-md-start">
                        <p class="mb-0 text-muted">© 2023 GodTur Travel. All rights reserved.</p>
                    </div>
                    <div class="col-md-6 text-center text-md-end">
                        <ul class="list-inline mb-0">
                            <li class="list-inline-item"><a href="terms" class="text-muted">Terms</a></li>
                            <li class="list-inline-item"><a href="privacy" class="text-muted">Privacy</a></li>
                            <li class="list-inline-item"><a href="cookies" class="text-muted">Cookies</a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </footer>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>
