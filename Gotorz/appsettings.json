{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=godtur.db"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Amadeus": {
    "ClientId": "YOUR_AMADEUS_API_KEY",
    "ClientSecret": "YOUR_AMADEUS_API_SECRET"
  },
  "EmailSettings": {
    "FromEmail": "noreply@godtur.com",
    "FromName": "GodTur Travel",
    "SmtpServer": "smtp.example.com",
    "SmtpPort": 587,
    "SmtpUsername": "smtp_username",
    "SmtpPassword": "smtp_password"
  },
  "PaymentGateway": {
    "ApiKey": "YOUR_PAYMENT_GATEWAY_API_KEY",
    "SecretKey": "YOUR_PAYMENT_GATEWAY_SECRET_KEY",
    "Environment": "sandbox"
  }
}
