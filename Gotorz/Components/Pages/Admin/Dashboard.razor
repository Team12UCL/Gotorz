@page "/admin"
@using Shared.Models
@inject NavigationManager NavigationManager
@inject ILogger<Dashboard> Logger

<PageTitle>Admin Dashboard - GodTur</PageTitle>

<div class="row">
    <div class="col-12 mb-4">
        <h1 class="h3 mb-0 text-gray-800">Admin Dashboard</h1>
        <p class="text-muted">Welcome back, Admin! Here's what's happening on the GodTur platform.</p>
    </div>
</div>

<div class="row">
    <!-- Revenue Card -->
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-left-primary shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">
                            Revenue (Monthly)
                        </div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">$@String.Format("{0:N0}", monthlyRevenue)</div>
                    </div>
                    <div class="col-auto">
                        <i class="bi bi-currency-dollar fa-2x text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Bookings Card -->
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-left-success shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-success text-uppercase mb-1">
                            New Bookings (Monthly)
                        </div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">@monthlyBookings</div>
                    </div>
                    <div class="col-auto">
                        <i class="bi bi-calendar-check fa-2x text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Users Card -->
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-left-info shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-info text-uppercase mb-1">
                            Users
                        </div>
                        <div class="h5 mb-0 mr-3 font-weight-bold text-gray-800">@totalUsers</div>
                    </div>
                    <div class="col-auto">
                        <i class="bi bi-people fa-2x text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Support Tickets Card -->
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-left-warning shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">
                            Pending Support Tickets
                        </div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">@pendingTickets</div>
                    </div>
                    <div class="col-auto">
                        <i class="bi bi-ticket fa-2x text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <!-- Revenue Chart -->
    <div class="col-xl-8 col-lg-7">
        <div class="card shadow mb-4">
            <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between">
                <h6 class="m-0 font-weight-bold text-primary">Revenue Overview</h6>
                <div class="dropdown no-arrow">
                    <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" id="dropdownMenuButton" data-bs-toggle="dropdown">
                        <i class="bi bi-three-dots-vertical"></i>
                    </button>
                    <div class="dropdown-menu dropdown-menu-end">
                        <a class="dropdown-item" href="#">View Details</a>
                        <a class="dropdown-item" href="#">Export Report</a>
                    </div>
                </div>
            </div>
            <div class="card-body">
                <div class="chart-area">
                    <div style="height: 320px; position: relative;">
                        <!-- This would contain a chart in a real implementation -->
                        <div class="d-flex justify-content-center align-items-center h-100">
                            <div class="text-center">
                                <i class="bi bi-bar-chart-line text-primary" style="font-size: 3rem;"></i>
                                <p class="mt-2">Revenue trending upward by 12% this month</p>
                                <small class="text-muted">Click 'View Details' for a full breakdown</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Package Popularity Chart -->
    <div class="col-xl-4 col-lg-5">
        <div class="card shadow mb-4">
            <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between">
                <h6 class="m-0 font-weight-bold text-primary">Top Packages</h6>
                <div class="dropdown no-arrow">
                    <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" id="dropdownMenuButton" data-bs-toggle="dropdown">
                        <i class="bi bi-three-dots-vertical"></i>
                    </button>
                    <div class="dropdown-menu dropdown-menu-end">
                        <a class="dropdown-item" href="#">View All Packages</a>
                        <a class="dropdown-item" href="#">Export Report</a>
                    </div>
                </div>
            </div>
            <div class="card-body">
                <div class="chart-pie">
                    <div style="height: 320px; position: relative;">
                        <!-- This would contain a pie chart in a real implementation -->
                        <div class="d-flex flex-column justify-content-center h-100">
                            @foreach (var package in topPackages)
                            {
                                <div class="d-flex justify-content-between mb-2">
                                    <span>@package.Name</span>
                                    <span class="text-primary font-weight-bold">@package.Bookings bookings</span>
                                </div>
                                <div class="progress mb-3" style="height: 10px;">
                                    <div class="progress-bar bg-primary" role="progressbar" style="width: @(package.Percentage)%;" aria-valuenow="@package.Percentage" aria-valuemin="0" aria-valuemax="100"></div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <!-- Recent Bookings Table -->
    <div class="col-lg-6 mb-4">
        <div class="card shadow">
            <div class="card-header py-3 d-flex justify-content-between align-items-center">
                <h6 class="m-0 font-weight-bold text-primary">Recent Bookings</h6>
                <a href="/admin/bookings" class="btn btn-sm btn-primary">View All</a>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Reference</th>
                                <th>Customer</th>
                                <th>Package</th>
                                <th>Date</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var booking in recentBookings)
                            {
                                <tr>
                                    <td>@booking.BookingReference</td>
                                    <td>@booking.PrimaryContactName</td>
                                    <td>@booking.PackageName</td>
                                    <td>@booking.BookingDate.ToString("MM/dd/yyyy")</td>
                                    <td>
                                        <span class="badge bg-@GetStatusBadgeColor(booking.Status)">@booking.Status</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent User Activity -->
    <div class="col-lg-6 mb-4">
        <div class="card shadow">
            <div class="card-header py-3 d-flex justify-content-between align-items-center">
                <h6 class="m-0 font-weight-bold text-primary">Recent Activity</h6>
                <a href="/admin/users" class="btn btn-sm btn-primary">View All</a>
            </div>
            <div class="card-body">
                <div class="list-group">
                    @foreach (var activity in recentActivities)
                    {
                        <div class="list-group-item list-group-item-action flex-column align-items-start">
                            <div class="d-flex w-100 justify-content-between">
                                <h6 class="mb-1">@activity.UserEmail</h6>
                                <small class="text-muted">@GetTimeAgo(activity.Timestamp)</small>
                            </div>
                            <p class="mb-1">@activity.Action</p>
                            <small class="text-muted">@activity.IpAddress</small>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <!-- Active Support Chats -->
    <div class="col-xl-4 col-lg-5 mb-4">
        <div class="card shadow">
            <div class="card-header py-3 d-flex justify-content-between align-items-center">
                <h6 class="m-0 font-weight-bold text-primary">Active Chats</h6>
                <a href="/admin/support" class="btn btn-sm btn-primary">View All</a>
            </div>
            <div class="card-body">
                @if (activeChats.Count == 0)
                {
                    <div class="text-center py-4">
                        <i class="bi bi-chat-dots text-gray-400" style="font-size: 2rem;"></i>
                        <p class="mt-2 mb-0">No active support chats at the moment</p>
                    </div>
                }
                else
                {
                    <div class="list-group">
                        @foreach (var chat in activeChats)
                        {
                            <a href="/admin/support/chat/@chat.Id" class="list-group-item list-group-item-action flex-column align-items-start">
                                <div class="d-flex w-100 justify-content-between">
                                    <h6 class="mb-1">@chat.CustomerName</h6>
                                    <small class="text-muted">@GetTimeAgo(chat.LastMessage)</small>
                                </div>
                                <p class="mb-1 text-truncate">@chat.LastMessageText</p>
                                <small class="text-muted">Assigned to: @(string.IsNullOrEmpty(chat.AssignedAgent) ? "Unassigned" : chat.AssignedAgent)</small>
                            </a>
                        }
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- GDPR Requests -->
    <div class="col-xl-4 col-lg-4 mb-4">
        <div class="card shadow">
            <div class="card-header py-3 d-flex justify-content-between align-items-center">
                <h6 class="m-0 font-weight-bold text-primary">Pending GDPR Requests</h6>
                <a href="/admin/users" class="btn btn-sm btn-primary">Handle Requests</a>
            </div>
            <div class="card-body">
                @if (pendingGdprRequests.Count == 0)
                {
                    <div class="text-center py-4">
                        <i class="bi bi-shield-check text-gray-400" style="font-size: 2rem;"></i>
                        <p class="mt-2 mb-0">No pending GDPR requests</p>
                    </div>
                }
                else
                {
                    <div class="list-group">
                        @foreach (var request in pendingGdprRequests)
                        {
                            <div class="list-group-item list-group-item-action flex-column align-items-start">
                                <div class="d-flex w-100 justify-content-between">
                                    <h6 class="mb-1">@request.UserEmail</h6>
                                    <small class="text-muted">@request.RequestDate.ToString("MM/dd/yyyy")</small>
                                </div>
                                <p class="mb-1">@request.RequestType Request</p>
                                <div class="d-flex justify-content-end mt-2">
                                    <button class="btn btn-sm btn-outline-success me-2">Approve</button>
                                    <button class="btn btn-sm btn-outline-danger">Deny</button>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- System Status -->
    <div class="col-xl-4 col-lg-3 mb-4">
        <div class="card shadow">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-primary">System Status</h6>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-1">
                        <span>Server Load</span>
                        <span>42%</span>
                    </div>
                    <div class="progress" style="height: 10px;">
                        <div class="progress-bar bg-success" role="progressbar" style="width: 42%;" aria-valuenow="42" aria-valuemin="0" aria-valuemax="100"></div>
                    </div>
                </div>
                
                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-1">
                        <span>Database</span>
                        <span>67%</span>
                    </div>
                    <div class="progress" style="height: 10px;">
                        <div class="progress-bar bg-info" role="progressbar" style="width: 67%;" aria-valuenow="67" aria-valuemin="0" aria-valuemax="100"></div>
                    </div>
                </div>
                
                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-1">
                        <span>API Response Time</span>
                        <span>230ms</span>
                    </div>
                    <div class="progress" style="height: 10px;">
                        <div class="progress-bar bg-success" role="progressbar" style="width: 23%;" aria-valuenow="23" aria-valuemin="0" aria-valuemax="100"></div>
                    </div>
                </div>
                
                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-1">
                        <span>Storage</span>
                        <span>85%</span>
                    </div>
                    <div class="progress" style="height: 10px;">
                        <div class="progress-bar bg-warning" role="progressbar" style="width: 85%;" aria-valuenow="85" aria-valuemin="0" aria-valuemax="100"></div>
                    </div>
                </div>
                
                <div class="d-flex justify-content-between align-items-center mt-4">
                    <div>
                        <div class="d-flex align-items-center">
                            <div class="rounded-circle bg-success" style="width: 10px; height: 10px;"></div>
                            <span class="ms-2">API Services</span>
                        </div>
                        <div class="d-flex align-items-center mt-1">
                            <div class="rounded-circle bg-success" style="width: 10px; height: 10px;"></div>
                            <span class="ms-2">Database</span>
                        </div>
                    </div>
                    <div>
                        <div class="d-flex align-items-center">
                            <div class="rounded-circle bg-success" style="width: 10px; height: 10px;"></div>
                            <span class="ms-2">Payment Gateway</span>
                        </div>
                        <div class="d-flex align-items-center mt-1">
                            <div class="rounded-circle bg-success" style="width: 10px; height: 10px;"></div>
                            <span class="ms-2">Email Services</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    // Mock data for dashboard
    private decimal monthlyRevenue = 124500;
    private int monthlyBookings = 142;
    private int totalUsers = 2458;
    private int pendingTickets = 18;
    private List<PackageData> topPackages = new List<PackageData>();
    private List<Booking> recentBookings = new List<Booking>();
    private List<ActivityLog> recentActivities = new List<ActivityLog>();
    private List<SupportChat> activeChats = new List<SupportChat>();
    private List<GdprRequest> pendingGdprRequests = new List<GdprRequest>();

    protected override void OnInitialized()
    {
        // Initialize mock data
        InitializeTopPackages();
        InitializeRecentBookings();
        InitializeRecentActivities();
        InitializeActiveChats();
        InitializeGdprRequests();
    }

    private void InitializeTopPackages()
    {
        topPackages.Add(new PackageData { Name = "Paris Romance", Bookings = 35, Percentage = 80 });
        topPackages.Add(new PackageData { Name = "Tokyo Adventure", Bookings = 28, Percentage = 65 });
        topPackages.Add(new PackageData { Name = "New York City Escape", Bookings = 22, Percentage = 50 });
        topPackages.Add(new PackageData { Name = "Caribbean Cruise", Bookings = 18, Percentage = 40 });
        topPackages.Add(new PackageData { Name = "London Explorer", Bookings = 15, Percentage = 35 });
    }

    private void InitializeRecentBookings()
    {
        var random = new Random();
        var statuses = new[] { "Confirmed", "Pending", "Completed", "Cancelled" };
        var packages = new[] { "Paris Romance", "Tokyo Adventure", "New York City Escape", "Caribbean Cruise", "London Explorer" };
        var names = new[] { "John Smith", "Jane Johnson", "Robert Williams", "Emily Brown", "Michael Davis" };

        for (int i = 0; i < 5; i++)
        {
            var daysAgo = random.Next(0, 10);
            recentBookings.Add(new Booking
            {
                Id = Guid.NewGuid(),
                BookingReference = $"GT-{DateTime.Now.AddDays(-daysAgo):yyyyMMdd}-{random.Next(1000, 9999)}",
                PrimaryContactName = names[random.Next(names.Length)],
                PackageName = packages[random.Next(packages.Length)],
                BookingDate = DateTime.Now.AddDays(-daysAgo),
                Status = statuses[random.Next(statuses.Length)]
            });
        }
    }

    private void InitializeRecentActivities()
    {
        var actions = new[] { "Logged in", "Updated profile", "Booked a package", "Contacted support", "Updated payment info" };
        var emails = new[] { "john@example.com", "jane@example.com", "robert@example.com", "emily@example.com", "michael@example.com" };
        var ipAddresses = new[] { "192.168.1.1", "10.0.0.1", "172.16.0.1", "192.168.0.1", "10.0.0.2" };
        var random = new Random();

        for (int i = 0; i < 5; i++)
        {
            var minutesAgo = random.Next(1, 120);
            recentActivities.Add(new ActivityLog
            {
                Id = i,
                UserEmail = emails[random.Next(emails.Length)],
                Action = actions[random.Next(actions.Length)],
                Timestamp = DateTime.Now.AddMinutes(-minutesAgo),
                IpAddress = ipAddresses[random.Next(ipAddresses.Length)]
            });
        }
    }

    private void InitializeActiveChats()
    {
        var random = new Random();
        var names = new[] { "John Smith", "Jane Johnson", "Robert Williams", "Emily Brown" };
        var agents = new[] { "Agent Sarah", "Agent David", "Agent Lisa", "", "" }; // Some unassigned
        var messages = new[] { 
            "I need help with my booking", 
            "Can I get a refund?", 
            "When will I receive my tickets?",
            "Is there free wifi at the hotel?"
        };

        for (int i = 0; i < 3; i++)
        {
            var minutesAgo = random.Next(1, 30);
            activeChats.Add(new SupportChat
            {
                Id = i,
                CustomerName = names[random.Next(names.Length)],
                AssignedAgent = agents[random.Next(agents.Length)],
                LastMessage = DateTime.Now.AddMinutes(-minutesAgo),
                LastMessageText = messages[random.Next(messages.Length)]
            });
        }
    }

    private void InitializeGdprRequests()
    {
        var requestTypes = new[] { "Data Export", "Data Deletion", "Opt-Out" };
        var emails = new[] { "user1@example.com", "user2@example.com", "user3@example.com" };
        var random = new Random();

        for (int i = 0; i < 2; i++)
        {
            var daysAgo = random.Next(1, 5);
            pendingGdprRequests.Add(new GdprRequest
            {
                Id = i,
                UserEmail = emails[random.Next(emails.Length)],
                RequestType = requestTypes[random.Next(requestTypes.Length)],
                RequestDate = DateTime.Now.AddDays(-daysAgo)
            });
        }
    }

    private string GetStatusBadgeColor(string status)
    {
        return status switch
        {
            "Confirmed" => "success",
            "Pending" => "warning",
            "Completed" => "info",
            "Cancelled" => "danger",
            _ => "secondary"
        };
    }

    private string GetTimeAgo(DateTime dateTime)
    {
        var span = DateTime.Now - dateTime;

        if (span.TotalMinutes < 2)
            return "just now";
        if (span.TotalMinutes < 60)
            return $"{(int)span.TotalMinutes} minutes ago";
        if (span.TotalHours < 24)
            return $"{(int)span.TotalHours} hours ago";
        
        return $"{(int)span.TotalDays} days ago";
    }

    // View models for dashboard
    public class PackageData
    {
        public string Name { get; set; }
        public int Bookings { get; set; }
        public int Percentage { get; set; }
    }

    public class Booking
    {
        public Guid Id { get; set; }
        public string BookingReference { get; set; }
        public string PrimaryContactName { get; set; }
        public string PackageName { get; set; }
        public DateTime BookingDate { get; set; }
        public DateTime TravelDate { get; set; }
        public DateTime ReturnDate { get; set; }
        public decimal TotalAmount { get; set; }
        public string Status { get; set; }
        public string ContactEmail { get; set; }
        public string ContactPhone { get; set; }
        public int NumberOfTravelers { get; set; }
        public string PaymentMethod { get; set; }
        public string SpecialRequests { get; set; }
        public string CancellationReason { get; set; }
        public bool RefundProcessed { get; set; }
    }

    public class ActivityLog
    {
        public int Id { get; set; }
        public string UserEmail { get; set; }
        public string Action { get; set; }
        public DateTime Timestamp { get; set; }
        public string IpAddress { get; set; }
    }

    public class SupportChat
    {
        public int Id { get; set; }
        public string CustomerName { get; set; }
        public string AssignedAgent { get; set; }
        public DateTime LastMessage { get; set; }
        public string LastMessageText { get; set; }
    }

    public class GdprRequest
    {
        public int Id { get; set; }
        public string UserEmail { get; set; }
        public string RequestType { get; set; }
        public DateTime RequestDate { get; set; }
    }
}