@page "/package-details/{Id:guid}"
@using Shared.Models
@inject HttpClient Http
@inject NavigationManager NavigationManager

<PageTitle>Package Details - GodTur Travel</PageTitle>

@if (package == null)
{
    <div class="d-flex justify-content-center my-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else
{
    <div class="container my-5">
        <div class="row">
            <div class="col-lg-8">
                <div class="card mb-4">
                    <img src="@(string.IsNullOrEmpty(package.ImageUrl) ? "/images/default-hotel.jpg" : package.ImageUrl)" 
                         class="card-img-top" alt="@package.HotelName" style="height: 400px; object-fit: cover;">
                    <div class="card-body">
                        <h1 class="card-title">@package.Name</h1>
                        <p class="card-text">@package.Description</p>
                        
                        <div class="row mt-4">
                            <div class="col-md-6">
                                <h4>Flight Details</h4>
                                <ul class="list-group list-group-flush">
                                    <li class="list-group-item">
                                        <i class="bi bi-airplane me-2"></i>
                                        <strong>From:</strong> @package.OriginAirport
                                    </li>
                                    <li class="list-group-item">
                                        <i class="bi bi-airplane-fill me-2"></i>
                                        <strong>To:</strong> @package.DestinationAirport
                                    </li>
                                    <li class="list-group-item">
                                        <i class="bi bi-calendar-date me-2"></i>
                                        <strong>Departure:</strong> @package.DepartureDate.ToString("dddd, MMMM d, yyyy")
                                    </li>
                                    <li class="list-group-item">
                                        <i class="bi bi-calendar-date-fill me-2"></i>
                                        <strong>Return:</strong> @package.ReturnDate.ToString("dddd, MMMM d, yyyy")
                                    </li>
                                    <li class="list-group-item">
                                        <i class="bi bi-airline me-2"></i>
                                        <strong>Airline:</strong> @package.Airline
                                    </li>
                                    <li class="list-group-item">
                                        <i class="bi bi-ticket-detailed me-2"></i>
                                        <strong>Flight Number:</strong> @package.FlightNumber
                                    </li>
                                </ul>
                            </div>
                            <div class="col-md-6">
                                <h4>Hotel Details</h4>
                                <ul class="list-group list-group-flush">
                                    <li class="list-group-item">
                                        <i class="bi bi-building me-2"></i>
                                        <strong>Hotel:</strong> @package.HotelName
                                    </li>
                                    <li class="list-group-item">
                                        <i class="bi bi-geo-alt me-2"></i>
                                        <strong>Address:</strong> @package.HotelAddress
                                    </li>
                                    <li class="list-group-item">
                                        <i class="bi bi-star-fill me-2"></i>
                                        <strong>Rating:</strong> 
                                        @for (int i = 0; i < package.HotelRating; i++)
                                        {
                                            <i class="bi bi-star-fill text-warning"></i>
                                        }
                                    </li>
                                    <li class="list-group-item">
                                        <i class="bi bi-door-open me-2"></i>
                                        <strong>Room Type:</strong> @package.RoomType
                                    </li>
                                    <li class="list-group-item">
                                        <i class="bi bi-calendar-week me-2"></i>
                                        <strong>Stay Duration:</strong> @package.DurationInDays days
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="card sticky-top" style="top: 20px;">
                    <div class="card-header bg-primary text-white">
                        <h4 class="mb-0">Booking Summary</h4>
                    </div>
                    <div class="card-body">
                        <p class="fs-5 fw-bold mb-4">Total Price: $@package.TotalPrice.ToString("F2")</p>
                        
                        <div class="mb-3">
                            <label for="travelers" class="form-label">Number of Travelers</label>
                            <select @bind="travelers" class="form-select" id="travelers">
                                @for (int i = 1; i <= 4; i++)
                                {
                                    <option value="@i">@i @(i == 1 ? "Traveler" : "Travelers")</option>
                                }
                            </select>
                        </div>
                        
                        <div class="mb-3">
                            <label for="name" class="form-label">Full Name</label>
                            <input type="text" class="form-control" id="name" placeholder="Enter your full name" @bind="name">
                        </div>
                        
                        <div class="mb-3">
                            <label for="email" class="form-label">Email Address</label>
                            <input type="email" class="form-control" id="email" placeholder="Enter your email" @bind="email">
                        </div>
                        
                        <div class="mb-3">
                            <label for="phone" class="form-label">Phone Number</label>
                            <input type="tel" class="form-control" id="phone" placeholder="Enter your phone number" @bind="phone">
                        </div>
                        
                        <button @onclick="BookPackage" class="btn btn-primary w-100 btn-lg">Book Now</button>
                        
                        <div class="mt-3 small">
                            <p class="mb-1"><i class="bi bi-info-circle me-2"></i>No payment required now</p>
                            <p class="mb-0"><i class="bi bi-shield-check me-2"></i>Free cancellation up to 48 hours before departure</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@if (showBookingConfirmation)
{
    <div class="modal fade show" style="display: block; background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title">Booking Confirmed!</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body text-center">
                    <i class="bi bi-check-circle text-success" style="font-size: 4rem;"></i>
                    <h4 class="mt-3">Thank you for your booking!</h4>
                    <p>
                        We've sent a confirmation email to <strong>@email</strong> with all the details.
                        Your booking reference is <strong>@bookingReference</strong>.
                    </p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModal">Close</button>
                    <button type="button" class="btn btn-primary" @onclick="ViewBookings">View My Bookings</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public Guid Id { get; set; }
    
    private TravelPackage package;
    private int travelers = 1;
    private string name;
    private string email;
    private string phone;
    private bool showBookingConfirmation;
    private string bookingReference;
    
    protected override async Task OnInitializedAsync()
    {
        try
        {
            // In a real implementation, this would fetch from the API/database
            // For demo purposes, we'll create a sample package
            package = new TravelPackage
            {
                Id = Id,
                Name = "New York to Los Angeles Package",
                Description = "Enjoy a round-trip flight from JFK to LAX with American Airlines and 7 nights at the Marriott Los Angeles Downtown.",
                TotalPrice = 1299.99m,
                DepartureDate = DateTime.Today.AddDays(30),
                ReturnDate = DateTime.Today.AddDays(37),
                DurationInDays = 7,
                OriginAirport = "JFK",
                DestinationAirport = "LAX",
                Airline = "AA",
                FlightNumber = "AA123",
                HotelName = "Marriott Los Angeles Downtown",
                HotelAddress = "123 Main St, Los Angeles, CA 90012",
                HotelRating = 4,
                RoomType = "Deluxe King",
                Status = "Available",
                ImageUrl = "https://images.unsplash.com/photo-1582719478250-c89cae4dc85b?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxzZWFyY2h8Mnx8aG90ZWx8ZW58MHx8MHx8&auto=format&fit=crop&w=800&q=60"
            };
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading package: {ex.Message}");
        }
    }
    
    private void BookPackage()
    {
        // In a real app, this would send the booking data to the server
        bookingReference = $"GT-{DateTime.Now.ToString("yyyyMMdd")}-{new Random().Next(10000, 99999)}";
        showBookingConfirmation = true;
    }
    
    private void CloseModal()
    {
        showBookingConfirmation = false;
    }
    
    private void ViewBookings()
    {
        showBookingConfirmation = false;
        NavigationManager.NavigateTo("/my-bookings");
    }
}