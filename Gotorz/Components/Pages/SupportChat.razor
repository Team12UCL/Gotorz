@page "/support-chat"
@using Microsoft.AspNetCore.SignalR.Client
@using Shared.Models
@using System.Collections.Generic
@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthStateProvider
@implements IAsyncDisposable

<PageTitle>Customer Support - GodTur Travel</PageTitle>

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card shadow">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <i class="bi bi-chat-dots-fill me-2"></i> Live Support Chat
                    </h5>
                    <span class="badge bg-success">@connectionStatus</span>
                </div>
                <div class="card-body chat-container" style="height: 400px; overflow-y: auto;" id="chatBox">
                    @if (messages.Count == 0)
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-chat-square-text" style="font-size: 3rem; color: #ddd;"></i>
                            <p class="text-muted mt-3">No messages yet. Start a conversation with our support team!</p>
                        </div>
                    }
                    else
                    {
                        @foreach (var message in messages)
                        {
                            <div class="@(message.IsFromSupport ? "chat-message support" : "chat-message user")">
                                <div class="message-bubble @(message.IsFromSupport ? "support-bubble" : "user-bubble")">
                                    <div class="message-content">@message.Content</div>
                                    <div class="message-time">
                                        <small>@message.SentAt.ToString("hh:mm tt")</small>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                </div>
                <div class="card-footer">
                    <div class="input-group">
                        <input @bind="messageInput" 
                               @bind:event="oninput" 
                               @onkeyup="HandleKeyPress" 
                               type="text" 
                               class="form-control" 
                               placeholder="Type your message here..." 
                               disabled="@(!IsConnected)" />
                        <button @onclick="SendMessage" 
                                class="btn btn-primary" 
                                disabled="@(!IsConnected || string.IsNullOrWhiteSpace(messageInput))">
                            <i class="bi bi-send-fill"></i>
                        </button>
                    </div>
                    @if (!IsConnected)
                    {
                        <div class="alert alert-warning mt-3">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i> Connection to support chat is not established. Please try refreshing the page.
                        </div>
                    }
                </div>
            </div>
            
            <div class="card mt-4 shadow">
                <div class="card-header bg-light">
                    <h6 class="mb-0">Create Support Ticket</h6>
                </div>
                <div class="card-body">
                    <form>
                        <div class="mb-3">
                            <label for="subject" class="form-label">Subject</label>
                            <input type="text" class="form-control" id="subject" @bind="ticketSubject">
                        </div>
                        <div class="mb-3">
                            <label for="category" class="form-label">Category</label>
                            <select class="form-select" id="category" @bind="ticketCategory">
                                <option value="Booking">Booking Issue</option>
                                <option value="Payment">Payment Problem</option>
                                <option value="Cancellation">Cancellation Request</option>
                                <option value="General">General Inquiry</option>
                                <option value="Technical">Technical Support</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label for="description" class="form-label">Description</label>
                            <textarea class="form-control" id="description" rows="3" @bind="ticketDescription"></textarea>
                        </div>
                        <button type="button" class="btn btn-success" @onclick="CreateSupportTicket">
                            <i class="bi bi-ticket-detailed me-1"></i> Submit Ticket
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private HubConnection hubConnection;
    private List<ChatMessage> messages = new List<ChatMessage>();
    private string messageInput;
    private string connectionStatus = "Connecting...";
    private string userId = string.Empty;
    private string username = "Guest";
    private string roomId = "support-room-1"; // In a real app, this would be unique per user or ticket
    
    // Support ticket fields
    private string ticketSubject;
    private string ticketCategory = "General";
    private string ticketDescription;

    public bool IsConnected => hubConnection?.State == HubConnectionState.Connected;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity.IsAuthenticated)
        {
            userId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            username = user.Identity.Name;
        }
        else
        {
            userId = "guest-" + Guid.NewGuid().ToString();
            username = "Guest";
        }

        hubConnection = new HubConnectionBuilder()
            .WithUrl(NavigationManager.ToAbsoluteUri("/chathub"))
            .WithAutomaticReconnect()
            .Build();

        hubConnection.On<string, string>("ReceiveSupportMessage", (user, message) =>
        {
            var newMessage = new ChatMessage
            {
                SenderId = user == username ? userId : "support",
                Content = message,
                IsFromSupport = user != username,
                SentAt = DateTime.UtcNow
            };
            
            messages.Add(newMessage);
            StateHasChanged();
            ScrollToBottom();
        });

        hubConnection.On<string>("UserJoined", (message) =>
        {
            connectionStatus = "Connected";
            StateHasChanged();
        });

        try
        {
            await hubConnection.StartAsync();
            await hubConnection.SendAsync("JoinSupportRoom", roomId);
            connectionStatus = "Connected";
            
            // Add welcome message
            messages.Add(new ChatMessage
            {
                SenderId = "support",
                Content = "Welcome to GodTur support! How can we help you today?",
                IsFromSupport = true,
                SentAt = DateTime.UtcNow
            });
        }
        catch (Exception ex)
        {
            connectionStatus = "Connection failed";
            Console.WriteLine(ex.Message);
        }
    }

    private async Task SendMessage()
    {
        if (!string.IsNullOrWhiteSpace(messageInput) && IsConnected)
        {
            await hubConnection.SendAsync("SendSupportMessage", roomId, username, messageInput);
            messageInput = string.Empty;
        }
    }

    private async Task HandleKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SendMessage();
        }
    }

    private void ScrollToBottom()
    {
        // In a real app, you would use JS interop to scroll the chat window
    }

    private async Task CreateSupportTicket()
    {
        if (string.IsNullOrWhiteSpace(ticketSubject) || string.IsNullOrWhiteSpace(ticketDescription))
        {
            return;
        }

        // In a real app, this would call an API to create the ticket
        var ticketNumber = $"TKT-{DateTime.Now:yyyyMMdd}-{new Random().Next(1000, 9999)}";
        
        // Send a confirmation message in the chat
        if (IsConnected)
        {
            await hubConnection.SendAsync("SendSupportMessage", roomId, "System", 
                $"Thank you for submitting ticket #{ticketNumber}. A support agent will review it shortly.");
        }
        
        // Clear the form
        ticketSubject = string.Empty;
        ticketDescription = string.Empty;
        ticketCategory = "General";
    }

    public async ValueTask DisposeAsync()
    {
        if (hubConnection is not null)
        {
            await hubConnection.DisposeAsync();
        }
    }
}