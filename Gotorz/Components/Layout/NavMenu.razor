@using Microsoft.AspNetCore.Components.Authorization
@using Gotorz.Client.Services
@inject NavigationManager NavigationManager
@inject LocalizationService LocalizationService

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">
            <img src="/images/godtur-logo.png" alt="GodTur Logo" height="30" class="d-inline-block align-text-top me-2" />
            GodTur Travel
        </a>
        <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

<div class="@NavMenuCssClass nav-scrollable" @onclick="ToggleNavMenu">
    <nav class="flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <i class="bi bi-house-door-fill me-2"></i> @LocalizationService.GetTranslation("Home")
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="destinations">
                <i class="bi bi-globe me-2"></i> @LocalizationService.GetTranslation("Destinations")
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="deals">
                <i class="bi bi-tag-fill me-2"></i> @LocalizationService.GetTranslation("SpecialDeals")
            </NavLink>
        </div>
        
        <AuthorizeView>
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="orderhistory">
                        <i class="bi bi-briefcase-fill me-2"></i> @LocalizationService.GetTranslation("MyBookings")
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="chat">
                        <i class="bi bi-chat-dots-fill me-2"></i> @LocalizationService.GetTranslation("CustomerSupport")
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="gdpr">
                        <i class="bi bi-shield-check me-2"></i> @LocalizationService.GetTranslation("PersonalData")
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="account">
                        <i class="bi bi-person-circle me-2"></i> @LocalizationService.GetTranslation("MyAccount")
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="account/logout">
                        <i class="bi bi-box-arrow-right me-2"></i> @LocalizationService.GetTranslation("Logout")
                    </NavLink>
                </div>
                
                @* Admin section - only shown to admin users *@
                <AuthorizeView Roles="Admin">
                    <div class="nav-item px-3 mt-3">
                        <div class="admin-section-header">
                            <i class="bi bi-shield-lock me-2"></i> Admin
                        </div>
                    </div>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="admin/dashboard">
                            <i class="bi bi-speedometer2 me-2"></i> Dashboard
                        </NavLink>
                    </div>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="admin/packages">
                            <i class="bi bi-bag-plus me-2"></i> Manage Packages
                        </NavLink>
                    </div>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="admin/bookings">
                            <i class="bi bi-calendar-check me-2"></i> Manage Bookings
                        </NavLink>
                    </div>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="admin/users">
                            <i class="bi bi-people me-2"></i> Manage Users
                        </NavLink>
                    </div>
                </AuthorizeView>
            </Authorized>
            <NotAuthorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="account/login">
                        <i class="bi bi-box-arrow-in-right me-2"></i> @LocalizationService.GetTranslation("Login")
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="account/register">
                        <i class="bi bi-person-plus me-2"></i> @LocalizationService.GetTranslation("Register")
                    </NavLink>
                </div>
            </NotAuthorized>
        </AuthorizeView>
        
        <hr class="my-3" />
        
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="help">
                <i class="bi bi-question-circle me-2"></i> @LocalizationService.GetTranslation("HelpSupport")
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="about">
                <i class="bi bi-info-circle me-2"></i> @LocalizationService.GetTranslation("AboutUs")
            </NavLink>
        </div>
    </nav>
</div>

<style>
    .admin-section-header {
        color: #ff6a00;
        font-weight: bold;
        margin-bottom: 0.5rem;
        padding: 0.5rem 0;
        border-bottom: 1px solid rgba(255,255,255,0.2);
    }
</style>

@code {
    private bool collapseNavMenu = true;

    private string NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }
}

